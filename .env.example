CURSOR_API_KEY=
CLOUD_REPO_URL=https://github.com/you/your-connected-repo
CLOUD_REPO_REF=main
CLOUD_AUTO_CREATE_PR=false
CLOUD_SKIP_REVIEWER_REQUEST=true

# Модель Cloud Agent (см. @cursor/sdk): Composer 2
CURSOR_MODEL=composer-2

# Тема вместо CLI (опционально)
BLUEPRINT_TOPIC_RAW=

# MCP **mcp-kv** уже подключён в Cursor → Agents — отдельный URL не нужен.
# MCP_ASSUME_CURSOR_DASHBOARD=true — по умолчанию так и есть (передаём инструментам промпты без inline MCP).

# Только если хотите переопределить HTTP MCP из скрипта (редко нужно при dashboard):
# MCP_KV_HTTP_URL=
# MCP_KV_HTTP_BEARER=

MCP_KV_NANO_TOOL=nano_banana_pro
# NANO_REFERENCE_IMAGE_URLS=

NANO_RESOLUTION=1K

WORDSTAT_USE_MCP=true
WORDSTAT_NUM_PHRASES=10
WORDSTAT_REGIONS=225
WORDSTAT_DEVICES_JSON=["DEVICE_ALL"]

# WORDSTAT_FALLBACK_SURROGATE_ONLY=true
# NANO_SKIP=true

MID_ARTICLE_BANNER_IMAGE_URL=
FEATURED_IMAGE_URL=

WP_UPLOAD_MID_ARTICLE_BANNER_TO_MEDIA=true
WP_BANNER_UPLOAD_TITLE=Автоматизация соцсетей
WP_BANNER_UPLOAD_ALT=контентзавод

WP_POST_STATUS=publish
WP_POST_TYPE=posts

# Отдельный WordPress MCP endpoint (если не тот же kv в dashboard):
# WORDPRESS_MCP_HTTP_URL=
# WORDPRESS_MCP_HTTP_BEARER=
