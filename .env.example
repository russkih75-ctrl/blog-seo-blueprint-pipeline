CURSOR_API_KEY=

# ── Telegram-бот (локальный Agent SDK, см. README) ─────────────────────────
TELEGRAM_BOT_TOKEN=
# Корень репозитория для Agent.local.cwd (по умолчанию — каталог с package.json)
WORKSPACE_ROOT=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_AGENT_PERSONALITY=
TELEGRAM_AGENT_PERSONALITY_FILE=
BOT_TIMEZONE=
CONTEXT7_API_KEY=
# Путь к JSON очереди Wordstat для wp:wordstat-queue-next (по умолчанию config/wordprais-wordstat-automation.json)
# WORDSTAT_AUTOMATION_CONFIG=
# Тот же endpoint mcp-kv, что и для workflow (SSE URL вида …/mcp/sse/…): MCP_KV_HTTP_URL / MCP_KV_HTTP_BEARER
# или MCP_KV_DOTENV_PATH=.env.mcp.local — см. блок mcp-kv ниже.
# Для бота обязательны также CURSOR_MODEL и (при необходимости) остальные переменные ниже.

# ── Content Factory (универсальная SEO/GEO линия, см. README) ───────────────
# dry-run по умолчанию у CLI; publish только с --publish или publish здесь
CONTENT_PUBLISH_MODE=dry-run
SITE_HOST=
# IndexNow / Яндекс: публичный verification key по протоколу IndexNow (файл на домене) — это НЕ секретный API-token.
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=
# Совместимость: те же значения можно задать как YANDEX_INDEXNOW_VERIFICATION_KEY или устаревшее YANDEX_INDEXNOW_KEY; LOCATION аналогично через YANDEX_INDEXNOW_KEY_LOCATION.

# Метла (cleanerai): опциональный webhook — результат как у Make-модуля (cleaned image URL). API-key не требуется.
METLA_WEBHOOK_URL=
METLA_ENDPOINT=
METLA_REQUIRE=false

CLOUD_REPO_URL=https://github.com/you/your-connected-repo
CLOUD_REPO_REF=main
CLOUD_AUTO_CREATE_PR=false
CLOUD_SKIP_REVIEWER_REQUEST=true

# Модель Agent (@cursor/sdk). Для локального режима обязательна.
CURSOR_MODEL=composer-2

# Пустой / отсутствует = Cursor Cloud и GitHub‑репозиторий из CLOUD_REPO_URL (см. check:cloud-setup)
# WORKFLOW_RUNTIME=local — только локальный агент, без Remote GitHub‑клона Cursor

BLUEPRINT_TOPIC_RAW=

# Опционально: три сид-фразы JSON если модуль 39 не вернул JSON
# WORKFLOW_SEEDS_JSON={"k1":"фраза1","k2":"фраза2","k3":"фраза3"}

# ── GitHub для Cloud API (можно временно для отладки) ──────────────────────
# CLOUD_SKIP_REPO_CHECK=false
# при true пропускается ошибка до вызова Cloud (не рекомендуется).

# ── mcp-kv через HTTP (рекомендуется для пайплайна из CLI + Cursor Cloud) ─
# Endpoint и Bearer выдаются в личном кабинете https://mcp-kv.ru/
# Скопируйте также шаблон: .env.mcp.example → .env.mcp.local (в .gitignore) и строку ниже:
# MCP_KV_DOTENV_PATH=.env.mcp.local
#
# Другой путь к JSON Cursor с mcp-kv (иначе: %USERPROFILE%\.cursor\mcp.json)
# CURSOR_MCP_JSON_PATH=
#
# Endpoint из ЛК или автоматически из %USERPROFILE%\.cursor\mcp.json (как у вас в Cursor)
MCP_KV_HTTP_URL=
MCP_KV_HTTP_BEARER=
#
# У Node-клиента MCP SDK legacy-транспорт SSE часто «зависает» на hub mcp-kv.ru;
# бот и npm run mcp:tools-check используют Streamable HTTP (type=http) для этого хоста автоматически.
# Принудительно вернуть старый SSE-транспорт в Cursor SDK (обычно не нужно):
# MCP_KV_LEGACY_SSE_TRANSPORT=true
# Явный тип из ЛК (опционально): MCP_KV_HTTP_TYPE=sse (для НЕ mcp-kv.ru это может включить SSE по пути /sse/)
#
# Альтернатива: только URL/token в текстовых файлах первой строкой:
# MCP_KV_HTTP_URL_FILE=mcp-http-url.secret
# MCP_KV_HTTP_BEARER_FILE=mcp-http-bearer.secret
#
# После того как MCP_KV_HTTP_URL заполнен, включите жёсткую проверку:
# CLOUD_REQUIRE_MCP_KV_HTTP=true
#
MCP_ASSUME_CURSOR_DASHBOARD=true

MCP_KV_NANO_TOOL=nano_banana_pro
NANO_RESOLUTION=1K

WORDSTAT_USE_MCP=true
WORDSTAT_NUM_PHRASES=10
WORDSTAT_REGIONS=225
WORDSTAT_DEVICES_JSON=["DEVICE_ALL"]

MID_ARTICLE_BANNER_IMAGE_URL=
FEATURED_IMAGE_URL=

WP_UPLOAD_MID_ARTICLE_BANNER_TO_MEDIA=true
WP_BANNER_UPLOAD_TITLE=Автоматизация соцсетей
WP_BANNER_UPLOAD_ALT=контентзавод
WP_POST_STATUS=publish
WP_POST_TYPE=posts

WORDPRESS_MCP_HTTP_URL=
WORDPRESS_MCP_HTTP_BEARER=

# ── Fallback: прямой REST (без MCP), npm run wp:publish-pipeline ───────────
WORDPRESS_BASE_URL=https://example.com
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=
# WP_REST_POST_STATUS=publish
