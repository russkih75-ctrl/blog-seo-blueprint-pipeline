# Скопируйте рядом с проектом как `.env.mcp.local` и заполните (файл в .gitignore).
# Endpoint и токен HTTP MCP берутся в личном кабинете https://mcp-kv.ru/ (раздел для Cursor / API / HTTP MCP — как в вашей подписке).

MCP_KV_HTTP_URL=
MCP_KV_HTTP_BEARER=

# Укажите в основном .env строку MCP_KV_DOTENV_PATH=.env.mcp.local
# чтобы run-workflow подхватил эти секреты.
