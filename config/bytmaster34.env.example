# Пример переменных для публикации на https://bytmaster34.ru/
# Скопируйте строки в локальный .env или задайте в Cursor → Repository Secrets (не коммитить значения).

# REST WordPress (Application Password из админки WP — пробелы в пароле можно убрать)
WORDPRESS_BASE_URL=https://bytmaster34.ru
WORDPRESS_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# MCP mcp-kv — endpoint и bearer из ЛК https://mcp-kv.ru/
# В дашборде mcp-kv привяжите профиль WordPress к этому сайту.
# MCP_KV_DOTENV_PATH=.env.mcp.local

# Отдельная очередь Wordstat для этого сайта (не смешивать с wordprais)
WORDSTAT_AUTOMATION_CONFIG=config/bytmaster34-wordstat-automation.json

# Отдельный durable-журнал опубликованных ключей
WORDSTAT_PUBLISHED_PATH=data/wordstat-published-keywords.bytmaster34.json

# SSH/FTP из панели хостинга — для ручного деплоя файлов, НЕ для MCP wordpress_*.
# Не храните пароли в git:
# BYTMASTER34_SSH_HOST=
# BYTMASTER34_SSH_USER=
# BYTMASTER34_SSH_REMOTE_PATH=/bytmaster34.ru/
